# ZERODA Reflex 환경변수 템플릿
# 복사 후 실제 값으로 수정: cp .env.example /opt/zeroda-reflex/.env
# 보안: chmod 600 /opt/zeroda-reflex/.env

# ═══════════════════════════════════════
#  DB 경로 (Streamlit과 공유)
# ═══════════════════════════════════════
ZERODA_DB_PATH=/opt/zeroda-platform/zeroda.db

# ═══════════════════════════════════════
#  이메일 (네이버웍스 SMTP)
# ═══════════════════════════════════════
NAVER_SMTP_USER=
NAVER_SMTP_APP_PW=

# ═══════════════════════════════════════
#  SMS (SOLAPI / CoolSMS)
# ═══════════════════════════════════════
COOLSMS_API_KEY=
COOLSMS_API_SECRET=
COOLSMS_SENDER_PHONE=

# ═══════════════════════════════════════
#  기상청 API (공공데이터포털)
# ═══════════════════════════════════════
KMA_API_KEY=

# ═══════════════════════════════════════
#  AI (Anthropic Claude) — 선택사항
# ═══════════════════════════════════════
ANTHROPIC_API_KEY=
